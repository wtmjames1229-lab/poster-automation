# Production config for DigitalOcean VPS
# Copy to: /var/lib/etsy-ads/.env

DEPLOY_MODE=vps
APP_USER_DATA=/var/lib/etsy-ads

PRINTIFY_API_KEY=
PRINTIFY_EMAIL=
PRINTIFY_PASSWORD=
PRINTIFY_SHOP_ID=18634010

# false = disable off-site ads on all Etsy listings (watch default)
OFFSITE_ADS_ENABLED=false

# VPS production defaults (override only if needed)
PLAYWRIGHT_USE_PROFILE=true
PLAYWRIGHT_PREFER_SESSION=false
PLAYWRIGHT_HEADLESS=true
PRINTIFY_NAV_VIA_PRODUCTS=true
ADS_WATCH_AUTO_RELOGIN=true
ADS_WATCH_RETRY_FAILED=true
ADS_WATCH_DELAY_MS=1800
ADS_BLOCK_MEDIA=true

# Email alerts (recommended on VPS)
MAIL_TO=
MAIL_FROM=ads-watch@yourdomain.com
