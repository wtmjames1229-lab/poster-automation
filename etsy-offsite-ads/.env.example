# Copy to etsy-offsite-ads/.env (or use the root project .env)

PRINTIFY_API_KEY=
PRINTIFY_EMAIL=
PRINTIFY_PASSWORD=
PRINTIFY_SHOP_ID=18634010
PRINTIFY_SHOP_NAME=Snoopy

# Target state for watch mode and toggles: true = enable ads, false = disable (default)
OFFSITE_ADS_ENABLED=false

PLAYWRIGHT_USE_PROFILE=true
PLAYWRIGHT_PREFER_SESSION=false
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=90000
PRINTIFY_NAV_VIA_PRODUCTS=false

# --- Manual bulk sync (unchanged) ---
# ADS_SYNC_JOB_FILE=./data/ads-sync-job.json

# --- Automatic watch mode (set-and-forget) ---
# ADS_WATCH_STATE_FILE=./data/ads-watch-state.json
# ADS_WATCH_JOB_FILE=./data/ads-watch-job.json
# ADS_WATCH_RETRY_FAILED=true
# ADS_WATCH_DELAY_MS=1800
# ADS_WATCH_CANVAS_ONLY=false
# ADS_WATCH_NOTIFY_ON_SUCCESS=false

# --- Email alerts (watch mode) ---
# MAIL_TO=you@example.com
# MAIL_FROM=ads-watch@example.com
# Option A — SendGrid
# SENDGRID_API_KEY=
# Option B — SMTP (Gmail app password, etc.)
# MAIL_SMTP_HOST=smtp.gmail.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_USER=
# MAIL_SMTP_PASS=
