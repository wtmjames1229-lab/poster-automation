# Root .env — used by automation.js and copied into etsy-offsite-ads when needed.
# For GitHub Actions, set these as repository SECRETS (see GITHUB_SETUP.md).

# --- Printify ---
PRINTIFY_API_KEY=
PRINTIFY_EMAIL=
PRINTIFY_PASSWORD=
PRINTIFY_SHOP_ID=18634010

# --- Ads watch target: false = disable off-site ads (recommended) ---
OFFSITE_ADS_ENABLED=false

# --- Email alerts (watch mode) ---
MAIL_TO=
MAIL_FROM=
# SENDGRID_API_KEY=
# MAIL_SMTP_HOST=smtp.gmail.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_USER=
# MAIL_SMTP_PASS=

# --- POD automation (automation.js) — add your other keys below ---
